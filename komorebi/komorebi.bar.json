{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.39/schema.bar.json",
  "monitor": 0,
  "font_family": "JetBrainsMono Nerd Font",
  "font_size": 11.0,
  "theme": {
    "palette": "Catppuccin",
    "name": "Mocha",
    "accent": "Blue"
  },
  "height": 40,
  "icon_scale": 1.1,
  "grouping": {
    "kind": "Widget",
    "rounding": 4,
    "style": "DefaultWithGlowB3O1S2",
    "transparency_alpha": 0
  },
  "frame": {
    "inner_margin": {
      "x": 16,
      "y": 8
    }
  },
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": true
        },
        "layout": {
          "enable": true
        },
        "focused_window": {
          "enable": true,
          "show_icon": true
        }
      }
    }
  ],
  "right_widgets": [
    {
      "Cpu": {
        "enable": true,
        "label_prefix": "Icon"
      }
    },
    {
      "Memory": {
        "enable": true,
        "label_prefix": "Icon"
      }
    },
    {
      "Battery": {
        "enable": true,
        "label_prefix": "Icon"
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "YearMonthDate",
        "label_prefix": "Icon"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHourWithoutSeconds",
        "label_prefix": "Icon"
      }
    }
  ]
}
